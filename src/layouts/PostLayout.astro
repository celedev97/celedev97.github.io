---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date?: Date;
  tags?: string[];
  description?: string;
  slug?: string;
}

const { title, date, tags, description, slug } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const filename = (slug ? `/devlog/${slug}` : pathname) + '.md';

const formattedDate = date
  ? date.toISOString().split('T')[0]
  : null;
---

<BaseLayout title={title} description={description}>
  <div class="cmd-line">cat {filename}</div>

  <h1>{title}</h1>

  {(formattedDate || (tags && tags.length > 0)) && (
    <p class="post-slim-meta">
      {[
        formattedDate,
        ...(tags ?? []).map(t => `#${t}`)
      ].join(' · ')}
    </p>
  )}

  <slot />
</BaseLayout>
