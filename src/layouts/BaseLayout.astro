---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CeleDev97 — Personal site' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | CeleDev97</title>
    <link rel="icon" type="image/png" href="/img/celedev97.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-okaidia.min.css" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const TYPE_DURATION = 600; // ms total per command, regardless of length
      const AFTER_CMD_DELAY = 200;
      const BETWEEN_BLOCKS_DELAY = 300;

      const blocks = Array.from(document.querySelectorAll('.terminal-block'));
      if (!blocks.length) return;

      blocks.forEach(block => {
        const cmd = block.querySelector('.cmd-line, .home-prompt');
        const output = block.querySelector('.terminal-output');
        if (cmd) { cmd.dataset.text = cmd.textContent; cmd.textContent = ''; }
        if (output) output.style.visibility = 'hidden';
      });

      function typeCmd(cmd, done) {
        const text = cmd.dataset.text;
        const delay = Math.max(15, Math.round(TYPE_DURATION / text.length));
        let i = 0;
        cmd.classList.add('typing');
        const id = setInterval(() => {
          cmd.textContent = text.slice(0, ++i);
          if (i >= text.length) {
            clearInterval(id);
            cmd.classList.remove('typing');
            setTimeout(done, AFTER_CMD_DELAY);
          }
        }, delay);
      }

      function runBlock(index) {
        if (index >= blocks.length) return;
        const block = blocks[index];
        const cmd = block.querySelector('.cmd-line, .home-prompt');
        const output = block.querySelector('.terminal-output');
        if (!cmd) { runBlock(index + 1); return; }
        typeCmd(cmd, () => {
          if (output) output.style.visibility = 'visible';
          setTimeout(() => runBlock(index + 1), BETWEEN_BLOCKS_DELAY);
        });
      }

      setTimeout(() => runBlock(0), 200);
    });
  </script>
  </body>
</html>
